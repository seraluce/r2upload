    margin-bottom: 8px;
    animation: spin 1s linear infinite;
  }
</style>

<div class="files-section">
  <div class="files-header">
    <h3>
      <i data-lucide="folder-open" class="icon"></i>
      R2 Files
      <span class="file-count">({files.length})</span>
    </h3>
    <button class={`refresh-btn ${loading ? 'loading' : ''}`} onclick={onRefresh} disabled={loading}>
      <i data-lucide="refresh-cw" class="icon"></i>
      {loading ? 'Loading...' : 'Refresh'}
    </button>
  </div>

  {loading ? (
    <div class="loading-state">
      <i data-lucide="loader-circle" class="icon"></i>
      <div>Loading files...</div>
    </div>
  ) : files.length === 0 ? (
    <div class="empty-state">
      <i data-lucide="folder" class="icon"></i>
      <div>No files uploaded yet</div>
    </div>
  ) : (
    <div class="files-list">
      {files.map((file) => (
        <div class="file-item" key={file.key}>
          <i data-lucide={getFileIcon(file.name)} class="icon-file"></i>
          <div class="info">
            <div class="name" title={file.name}>{file.name}</div>
            <div class="meta">
              {formatFileSize(file.size)} · {formatTime(file.lastModified)}
            </div>
          </div>
          <div class="actions">
            {publicUrlPrefix && (
              <button class="action-btn" onclick={() => copyUrl(file.key)} title="Copy URL">
                <i data-lucide="link" class="icon"></i>
              </button>
            )}
            <button class="action-btn delete" onclick={() => onDelete(file.key)} title="Delete">
              <i data-lucide="trash-2" class="icon"></i>
            </button>
          </div>
        </div>
      ))}
    </div>
  )}
</div>
