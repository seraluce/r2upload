    padding-top: 20px;
    border-top: 1px solid var(--border);
  }

  .files-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .files-header h3 {
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .files-header .icon {
    width: 18px;
    height: 18px;
    color: var(--text-muted);
    stroke-width: 1.8;
  }

  .files-header .refresh-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--text-muted);
    background: none;
    border: 1px solid var(--border);
    cursor: pointer;
    padding: 6px 10px;
    border-radius: var(--radius);
    transition: all var(--transition);
  }

  .files-header .refresh-btn:hover {
    background: var(--bg-tertiary);
    color: var(--text-secondary);
  }

  .files-header .refresh-btn .icon {
