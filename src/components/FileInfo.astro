<script>
  interface Props {
    filename?: string;
    size?: number;
    status: 'ready' | 'uploading' | 'success' | 'error';
    statusText: string;
  }

  const { filename, size, status, statusText } = Astro.props;

  const formatFileSize = (bytes: number): string => {
    if (bytes === 0) return '0 B';
    const units = ['B', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(1024));
    const size = (bytes / Math.pow(1024, i)).toFixed(1);
    return `${size} ${units[i]}`;
  };

  const getFileIcon = (filename: string): string => {
    const ext = filename.substring(filename.lastIndexOf('.')).toLowerCase();
    const iconMap: Record<string, string> = {
      '.pdf': 'file-text',
      '.doc': 'file-text',
      '.docx': 'file-text',
      '.txt': 'file-text',
      '.md': 'file-text',
      '.jpg': 'image',
      '.jpeg': 'image',
      '.png': 'image',
      '.gif': 'image',
      '.svg': 'image',
      '.webp': 'image',
      '.mp4': 'video',
      '.mov': 'video',
      '.avi': 'video',
      '.mp3': 'music',
      '.wav': 'music',
      '.zip': 'archive',
      '.rar': 'archive',
      '.tar': 'archive',
      '.gz': 'archive',
      '.json': 'file-code',
      '.js': 'file-code',
      '.ts': 'file-code',
      '.html': 'file-code',
      '.css': 'file-code',
      '.csv': 'file-spreadsheet',
      '.xls': 'file-spreadsheet',
      '.xlsx': 'file-spreadsheet',
      '.ppt': 'file-presentation',
      '.pptx': 'file-presentation',
    };
    return iconMap[ext] || 'file';
  };
</script>

<style>
  .file-info {
    background: var(--bg-secondary);
    border-radius: var(--radius);
    border: 1px solid var(--border);
    padding: 12px 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
    min-height: 52px;
    gap: 12px;
    flex-wrap: wrap;
  }

  .file-info .details {
    display: flex;
    align-items: center;
    gap: 10px;
    flex: 1;
    min-width: 0;
  }

  .file-info .details .icon-file {
    color: var(--text-muted);
    flex-shrink: 0;
    stroke-width: 1.8;
  }

  .file-info .details .name {
    font-weight: 500;
    color: var(--text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: 14px;
  }

  .file-info .details .size {
    font-size: 12px;
    color: var(--text-muted);
    background: var(--bg);
    padding: 1px 10px;
    border-radius: 20px;
    border: 1px solid var(--border);
    white-space: nowrap;
  }

  .file-info .details .empty {
    color: var(--text-muted);
    font-weight: 400;
    font-size: 14px;
  }

  .file-info .status-badge {
    font-size: 12px;
    font-weight: 500;
    padding: 3px 12px;
    border-radius: 20px;
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 6px;
    border: 1px solid var(--border);
    background: var(--bg);
  }

  .file-info .status-badge .icon {
    width: 14px;
    height: 14px;
    stroke-width: 2;
  }

  .file-info .status-badge.ready {
    color: var(--text-secondary);
    border-color: var(--border);
  }

  .file-info .status-badge.ready .icon {
    color: var(--text-muted);
  }

  .file-info .status-badge.uploading {
    color: var(--warning);
    border-color: rgba(245, 158, 11, 0.3);
    background: rgba(245, 158, 11, 0.1);
    animation: pulse 1.2s ease-in-out infinite;
  }

  .file-info .status-badge.uploading .icon {
    color: var(--warning);
  }

  .file-info .status-badge.success {
    color: var(--success);
    border-color: rgba(16, 185, 129, 0.3);
    background: rgba(16, 185, 129, 0.1);
  }

  .file-info .status-badge.success .icon {
    color: var(--success);
  }

  .file-info .status-badge.error {
    color: var(--danger);
    border-color: rgba(239, 68, 68, 0.3);
    background: rgba(239, 68, 68, 0.1);
  }

  .file-info .status-badge.error .icon {
    color: var(--danger);
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }

  @media (max-width: 600px) {
    .file-info {
      flex-direction: column;
      align-items: stretch;
      gap: 8px;
    }

    .file-info .details {
      flex-wrap: wrap;
    }
  }
</style>

<div class="file-info">
  <div class="details">
    <i data-lucide={filename ? getFileIcon(filename) : 'file'} class="icon-file" width="18" height="18"></i>
    <span class={filename ? 'name' : 'empty'}>{filename || 'No file selected'}</span>
    {size && <span class="size">{formatFileSize(size)}</span>}
  </div>
  <span class={`status-badge ${status}`}>
    <i data-lucide={status === 'ready' ? 'circle' : status === 'uploading' ? 'loader-circle' : status === 'success' ? 'check-circle' : 'x-circle'} class="icon"></i>
    {statusText}
  </span>
</div>
