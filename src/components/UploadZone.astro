<script>
  interface Props {
    onFileSelect: (file: File) => void;
    disabled?: boolean;
  }

  const { onFileSelect, disabled = false } = Astro.props;

  const handleDrop = (e: DragEvent) => {
    e.preventDefault();
    const dropZone = e.currentTarget as HTMLElement;
    dropZone.classList.remove('dragover');
    if (disabled) return;
    
    const files = e.dataTransfer?.files;
    if (files && files.length > 0) {
      onFileSelect(files[0]);
    }
  };

  const handleDragOver = (e: DragEvent) => {
    e.preventDefault();
    if (!disabled) {
      (e.currentTarget as HTMLElement).classList.add('dragover');
    }
  };

  const handleDragLeave = (e: DragEvent) => {
    e.preventDefault();
    (e.currentTarget as HTMLElement).classList.remove('dragover');
  };

  const handleClick = () => {
    if (!disabled) {
      const input = document.getElementById('fileInput') as HTMLInputElement;
      input.click();
    }
  };

  const handleFileChange = (e: Event) => {
    const input = e.target as HTMLInputElement;
    const file = input.files?.[0];
    if (file) {
      onFileSelect(file);
    }
  };
</script>

<style>
  .upload-zone {
    border: 2px dashed var(--border);
    border-radius: var(--radius-lg);
    padding: 48px 20px;
    text-align: center;
    cursor: pointer;
    transition: border-color var(--transition), background var(--transition);
    background: var(--bg-secondary);
    margin-bottom: 24px;
    position: relative;
  }

  .upload-zone:hover:not(:disabled) {
    border-color: var(--primary);
    background: rgba(59, 130, 246, 0.05);
  }

  .upload-zone.dragover {
    border-color: var(--primary);
    background: rgba(59, 130, 246, 0.1);
    border-style: solid;
  }

  .upload-zone:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .upload-zone .icon-upload {
    display: block;
    margin: 0 auto 14px;
    color: var(--text-muted);
    stroke-width: 1.5;
    transition: color var(--transition);
  }

  .upload-zone:hover:not(:disabled) .icon-upload {
    color: var(--primary);
  }

  .upload-zone .title {
    font-size: 16px;
    font-weight: 500;
    color: var(--text);
  }

  .upload-zone .subtitle {
    color: var(--text-muted);
    font-size: 13px;
    margin-top: 4px;
  }

  .upload-zone .hint {
    color: var(--text-muted);
    font-size: 12px;
    margin-top: 14px;
    display: inline-block;
    padding: 2px 14px;
    border-radius: 20px;
    background: var(--bg);
    border: 1px solid var(--border);
  }

  #fileInput {
    display: none;
  }

  @media (max-width: 600px) {
    .upload-zone {
      padding: 32px 16px;
    }

    .upload-zone .icon-upload {
      width: 40px;
      height: 40px;
    }
  }
</style>

<div 
  class="upload-zone" 
  ondrop={handleDrop}
  ondragover={handleDragOver}
  ondragleave={handleDragLeave}
  onclick={handleClick}
  disabled={disabled}
>
  <i data-lucide="upload" class="icon-upload" width="48" height="48"></i>
  <div class="title">Click or drag file to upload</div>
  <div class="subtitle">All file types supported</div>
  <div class="hint">Max 100MB · Single file</div>
  <input type="file" id="fileInput" onchange={handleFileChange} />
</div>
