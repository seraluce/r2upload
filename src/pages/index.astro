<!DOCTYPE html>
<html lang="zh-CN" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>R2 上传</title>
  <script src="https://unpkg.com/lucide@latest" is:inline></script>
  <style>
    :root {
      --bg: #ffffff;
      --bg-secondary: #fafafa;
      --bg-tertiary: #f4f4f5;
      --border: #eaeaea;
      --border-dark: #000000;
      --text: #000000;
      --text-secondary: #666666;
      --text-muted: #999999;
      --radius: 8px;
      --font: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      --mono: 'SF Mono', 'Monaco', 'Menlo', 'Consolas', monospace;
    }

    [data-theme="dark"] {
      --bg: #000000;
      --bg-secondary: #0a0a0a;
      --bg-tertiary: #111111;
      --border: #262626;
      --border-dark: #ffffff;
      --text: #ededed;
      --text-secondary: #888888;
      --text-muted: #666666;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: var(--font);
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
      transition: background 0.15s ease, color 0.15s ease;
    }

    .page-container {
      display: flex;
      justify-content: center;
      min-height: 100vh;
      padding: 40px 24px;
    }

    .card {
      width: 100%;
      max-width: 640px;
    }

    /* Header */
    .header { margin-bottom: 32px; }
    .header-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
    .header-title { display: flex; align-items: center; gap: 10px; }
    .header-title .logo-icon { width: 24px; height: 24px; color: var(--text); stroke-width: 1.5; }
    .header-title h1 { font-size: 20px; font-weight: 600; letter-spacing: -0.02em; }
    .theme-toggle { background: transparent; border: 1px solid var(--border); border-radius: var(--radius); width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: background 0.15s ease; }
    .theme-toggle:hover { background: var(--bg-tertiary); }
    .theme-toggle .icon { width: 16px; height: 16px; color: var(--text-secondary); stroke-width: 1.5; }
    .header-desc { font-size: 14px; color: var(--text-secondary); }

    /* Upload Zone */
    .upload-zone { border: 1px dashed var(--border); border-radius: var(--radius); padding: 40px 20px; text-align: center; cursor: pointer; transition: border-color 0.15s ease, background 0.15s ease; background: var(--bg-secondary); margin-bottom: 16px; }
    .upload-zone:hover { border-color: var(--text-secondary); }
    .upload-zone.dragover { border-color: var(--border-dark); border-style: solid; background: var(--bg-tertiary); }
    .upload-zone.disabled { opacity: 0.5; cursor: not-allowed; }
    .upload-zone .upload-icon { width: 32px; height: 32px; color: var(--text-muted); stroke-width: 1; margin-bottom: 12px; }
    .upload-zone .upload-title { font-size: 14px; font-weight: 500; color: var(--text); margin-bottom: 4px; }
    .upload-zone .upload-subtitle { font-size: 13px; color: var(--text-muted); }
    #fileInput { display: none; }

    /* File Info */
    .file-info { border: 1px solid var(--border); border-radius: var(--radius); padding: 12px 16px; display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; gap: 12px; flex-wrap: wrap; background: var(--bg); }
    .file-info .details { display: flex; align-items: center; gap: 8px; flex: 1; min-width: 0; }
    .file-info .icon-file { width: 16px; height: 16px; color: var(--text-muted); stroke-width: 1.5; flex-shrink: 0; }
    .file-info .name { font-size: 13px; font-weight: 500; color: var(--text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .file-info .empty { font-size: 13px; color: var(--text-muted); }
    .file-info .size { font-size: 12px; color: var(--text-muted); font-family: var(--mono); white-space: nowrap; }
    .status-badge { font-size: 12px; font-weight: 500; padding: 2px 10px; border-radius: 6px; white-space: nowrap; display: flex; align-items: center; gap: 4px; border: 1px solid var(--border); }
    .status-badge .icon { width: 12px; height: 12px; stroke-width: 2; }
    .status-badge.ready { color: var(--text-muted); }
    .status-badge.uploading { color: var(--text); border-color: var(--border-dark); }
    .status-badge.success { color: var(--text); border-color: var(--text); background: var(--bg-tertiary); }
    .status-badge.error { color: var(--text); border-color: var(--text); }

    /* Actions */
    .actions { display: flex; gap: 8px; margin-bottom: 12px; }
    .btn { flex: 1; padding: 8px 16px; border: 1px solid var(--border); border-radius: var(--radius); font-size: 13px; font-weight: 500; cursor: pointer; transition: background 0.15s ease; display: flex; align-items: center; justify-content: center; gap: 6px; background: var(--bg); color: var(--text); font-family: var(--font); }
    .btn .icon { width: 14px; height: 14px; stroke-width: 1.5; flex-shrink: 0; }
    .btn:hover:not(:disabled) { background: var(--bg-tertiary); }
    .btn:disabled { opacity: 0.4; cursor: not-allowed; }
    .btn-primary { background: var(--text); color: var(--bg); border-color: var(--text); }
    .btn-primary:hover:not(:disabled) { opacity: 0.9; background: var(--text); }
    .btn-primary .icon { color: var(--bg); }

    /* Progress */
    .progress-wrapper { margin-bottom: 12px; display: none; }
    .progress-wrapper.active { display: block; }
    .progress-bar { width: 100%; height: 2px; background: var(--border); border-radius: 1px; overflow: hidden; }
    .progress-bar .fill { height: 100%; background: var(--text); width: 0%; transition: width 0.3s ease; }
    .progress-text { display: flex; justify-content: space-between; font-size: 12px; color: var(--text-muted); margin-top: 4px; font-family: var(--mono); }

    /* Message */
    .message { padding: 10px 14px; border: 1px solid var(--border); border-radius: var(--radius); font-size: 13px; display: flex; align-items: center; gap: 8px; color: var(--text-secondary); margin-bottom: 24px; }
    .message .icon { width: 14px; height: 14px; stroke-width: 1.5; flex-shrink: 0; }
    .message.info .icon { color: var(--text-muted); }
    .message.success { border-color: var(--text); }
    .message.success .icon { color: var(--text); }
    .message.error { border-color: var(--text); }
    .message.error .icon { color: var(--text); }
    .message.warning { border-color: var(--text); }
    .message.warning .icon { color: var(--text); }

    /* Divider */
    .divider { height: 1px; background: var(--border); margin: 24px 0; }

    /* File List */
    .files-section { }
    .files-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
    .files-header h3 { font-size: 14px; font-weight: 600; color: var(--text); display: flex; align-items: center; gap: 6px; letter-spacing: -0.01em; }
    .files-header .icon { width: 16px; height: 16px; color: var(--text-secondary); stroke-width: 1.5; }
    .file-count { font-size: 12px; color: var(--text-muted); font-weight: 400; font-family: var(--mono); }
    .refresh-btn { display: flex; align-items: center; gap: 4px; font-size: 12px; color: var(--text-secondary); background: var(--bg); border: 1px solid var(--border); cursor: pointer; padding: 4px 10px; border-radius: var(--radius); transition: background 0.15s ease; font-family: var(--font); }
    .refresh-btn:hover { background: var(--bg-tertiary); }
    .refresh-btn .icon { width: 12px; height: 12px; stroke-width: 1.5; }
    .refresh-btn.loading .icon { animation: spin 1s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }

    .files-list { border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
    .file-item { display: flex; align-items: center; gap: 10px; padding: 10px 14px; border-bottom: 1px solid var(--border); font-size: 13px; transition: background 0.15s ease; }
    .file-item:last-child { border-bottom: none; }
    .file-item:hover { background: var(--bg-secondary); }
    .file-item .icon-file { width: 16px; height: 16px; color: var(--text-muted); stroke-width: 1.5; flex-shrink: 0; }
    .file-item .info { flex: 1; min-width: 0; }
    .file-item .info .name { color: var(--text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 13px; }
    .file-item .info .meta { color: var(--text-muted); font-size: 11px; margin-top: 2px; font-family: var(--mono); }
    .file-item .actions { display: flex; gap: 4px; flex-shrink: 0; margin: 0; }
    .file-item .action-btn { width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; background: transparent; border: none; border-radius: 6px; cursor: pointer; transition: background 0.15s ease; padding: 0; }
    .file-item .action-btn:hover { background: var(--bg-tertiary); }
    .file-item .action-btn .icon { width: 14px; height: 14px; stroke-width: 1.5; color: var(--text-muted); }
    .file-item .action-btn.delete:hover .icon { color: var(--text); }

    .empty-state { text-align: center; padding: 40px 20px; color: var(--text-muted); font-size: 13px; border: 1px solid var(--border); border-radius: var(--radius); }
    .empty-state .icon { width: 28px; height: 28px; margin-bottom: 8px; opacity: 0.3; }
    .loading-state { text-align: center; padding: 40px 20px; color: var(--text-muted); font-size: 13px; border: 1px solid var(--border); border-radius: var(--radius); }
    .loading-state .icon { width: 20px; height: 20px; margin-bottom: 8px; animation: spin 1s linear infinite; }

    /* Footer */
    .footer { margin-top: 32px; text-align: center; font-size: 12px; color: var(--text-muted); display: flex; align-items: center; justify-content: center; gap: 8px; flex-wrap: wrap; }
    .footer .icon { width: 12px; height: 12px; stroke-width: 1.5; }
    .footer .divider-text { color: var(--border); }
    .footer a { color: var(--text-muted); text-decoration: none; display: inline-flex; align-items: center; gap: 4px; transition: color 0.15s ease; }
    .footer a:hover { color: var(--text); }

    @media (max-width: 600px) {
      .page-container { padding: 20px 16px; }
      .file-info { flex-direction: column; align-items: stretch; gap: 8px; }
      .actions .btn { padding: 8px 12px; font-size: 12px; }
    }
  </style>
</head>
<body>
  <!-- fileInput 放在 uploadZone 外部，避免事件冒泡冲突 -->
  <input type="file" id="fileInput" style="display:none;" />

  <div class="page-container">
    <div class="card">
      <!-- Header -->
      <div class="header">
        <div class="header-top">
          <div class="header-title">
            <i data-lucide="hard-drive" class="logo-icon"></i>
            <h1>R2 上传</h1>
          </div>
          <button class="theme-toggle" id="themeToggle">
            <i data-lucide="moon" class="icon" id="themeIcon"></i>
          </button>
        </div>
        <p class="header-desc">使用预签名 URL 直传至 Cloudflare R2，无需服务端中转</p>
      </div>

      <!-- Upload Zone -->
      <div class="upload-zone" id="uploadZone">
        <i data-lucide="upload" class="upload-icon"></i>
        <div class="upload-title">点击或拖拽文件到此处上传</div>
        <div class="upload-subtitle">支持所有文件类型，单个文件最大 100MB</div>
      </div>

      <!-- File Info -->
      <div class="file-info" id="fileInfo">
        <div class="details">
          <i data-lucide="file" class="icon-file"></i>
          <span class="empty" id="fileName">未选择文件</span>
          <span class="size" id="fileSize" style="display:none;"></span>
        </div>
        <span class="status-badge ready" id="statusBadge">
          <i data-lucide="circle" class="icon"></i>
          <span id="statusText">就绪</span>
        </span>
      </div>

      <!-- Actions -->
      <div class="actions">
        <button class="btn" id="clearBtn">
          <i data-lucide="x" class="icon"></i>
          清除
        </button>
        <button class="btn btn-primary" id="uploadBtn" disabled>
          <i data-lucide="arrow-up" class="icon" id="uploadBtnIcon"></i>
          <span id="uploadBtnText">上传到 R2</span>
        </button>
      </div>

      <!-- Progress -->
      <div class="progress-wrapper" id="progressWrapper">
        <div class="progress-bar">
          <div class="fill" id="progressFill" style="width: 0%;"></div>
        </div>
        <div class="progress-text">
          <span id="progressPercent">0%</span>
          <span id="progressStatus">就绪</span>
        </div>
      </div>

      <!-- Message -->
      <div class="message info" id="message">
        <i data-lucide="info" class="icon" id="messageIcon"></i>
        <span id="messageText">请选择文件并点击上传，或拖拽文件到上方区域</span>
      </div>

      <div class="divider"></div>

      <!-- File List -->
      <div class="files-section">
        <div class="files-header">
          <h3>
            <i data-lucide="folder-open" class="icon"></i>
            R2 文件
            <span class="file-count" id="fileCount">0</span>
          </h3>
          <button class="refresh-btn" id="refreshBtn">
            <i data-lucide="refresh-cw" class="icon"></i>
            刷新
          </button>
        </div>
        <div id="filesListContainer">
          <div class="loading-state">
            <i data-lucide="loader-circle" class="icon"></i>
            <div>加载中...</div>
          </div>
        </div>
      </div>

      <!-- Footer -->
      <div class="footer">
        <i data-lucide="lock" class="icon"></i>
        前端直传 R2
        <span class="divider-text">/</span>
        预签名 URL 有效期 5 分钟
        <span class="divider-text">/</span>
        <a href="/admin">
          <i data-lucide="settings" class="icon"></i>
          管理后台
        </a>
      </div>
    </div>
  </div>

  <script is:inline>
    // Safe lucide wrapper
    function renderIcons() {
      try { if (window.lucide) lucide.createIcons(); } catch(e) {}
    }

    const savedTheme = localStorage.getItem('theme') || 'light';
    document.documentElement.setAttribute('data-theme', savedTheme);

    let currentFile = null;
    let isUploading = false;
    const MAX_SIZE = 100 * 1024 * 1024;

    const uploadZone = document.getElementById('uploadZone');
    const fileInput = document.getElementById('fileInput');

    // Theme toggle
    document.getElementById('themeToggle').addEventListener('click', () => {
      const currentTheme = document.documentElement.getAttribute('data-theme');
      const newTheme = currentTheme === 'light' ? 'dark' : 'light';
      document.documentElement.setAttribute('data-theme', newTheme);
      localStorage.setItem('theme', newTheme);
      updateThemeIcon();
    });

    function updateThemeIcon() {
      const theme = document.documentElement.getAttribute('data-theme');
      const icon = document.getElementById('themeIcon');
      icon.setAttribute('data-lucide', theme === 'dark' ? 'sun' : 'moon');
      renderIcons();
    }

    function formatFileSize(bytes) {
      if (bytes === 0) return '0 B';
      const units = ['B', 'KB', 'MB', 'GB', 'TB'];
      const i = Math.floor(Math.log(bytes) / Math.log(1024));
      return `${(bytes / Math.pow(1024, i)).toFixed(1)} ${units[i]}`;
    }

    function formatTime(isoString) {
      const date = new Date(isoString);
      return date.toLocaleString('zh-CN', { month:'2-digit', day:'2-digit', hour:'2-digit', minute:'2-digit' });
    }

    function getFileIcon(filename) {
      const ext = filename.substring(filename.lastIndexOf('.')).toLowerCase();
      const iconMap = {
        '.pdf':'file-text','.doc':'file-text','.docx':'file-text','.txt':'file-text','.md':'file-text',
        '.jpg':'image','.jpeg':'image','.png':'image','.gif':'image','.svg':'image','.webp':'image','.bmp':'image',
        '.mp4':'video','.mov':'video','.avi':'video','.webm':'video','.mkv':'video',
        '.mp3':'music','.wav':'music','.flac':'music','.ogg':'music',
        '.zip':'archive','.rar':'archive','.tar':'archive','.gz':'archive','.7z':'archive',
        '.json':'file-code','.js':'file-code','.ts':'file-code','.html':'file-code','.css':'file-code','.py':'file-code',
        '.csv':'file-spreadsheet','.xls':'file-spreadsheet','.xlsx':'file-spreadsheet',
        '.ppt':'file-presentation','.pptx':'file-presentation',
      };
      return iconMap[ext] || 'file';
    }

    function setMessage(text, type) {
      const msg = document.getElementById('message');
      const msgText = document.getElementById('messageText');
      const msgIcon = document.getElementById('messageIcon');
      const iconMap = { info:'info', success:'check-circle', error:'alert-circle', warning:'alert-triangle' };
      msg.className = `message ${type}`;
      msgText.textContent = text;
      msgIcon.setAttribute('data-lucide', iconMap[type] || 'info');
      renderIcons();
    }

    function setStatus(status, text) {
      const badge = document.getElementById('statusBadge');
      const statusText = document.getElementById('statusText');
      const badgeIcon = badge.querySelector('.icon');
      const iconMap = { ready:'circle', uploading:'loader-circle', success:'check-circle', error:'x-circle' };
      badge.className = `status-badge ${status}`;
      statusText.textContent = text;
      badgeIcon.setAttribute('data-lucide', iconMap[status] || 'circle');
      renderIcons();
    }

    function updateProgress(percent, status) {
      document.getElementById('progressFill').style.width = `${Math.min(percent, 100)}%`;
      document.getElementById('progressPercent').textContent = `${Math.min(percent, 100)}%`;
      document.getElementById('progressStatus').textContent = status;
    }

    function resetFileSelection() {
      currentFile = null;
      fileInput.value = '';
      document.getElementById('fileName').textContent = '未选择文件';
      document.getElementById('fileName').className = 'empty';
      document.getElementById('fileSize').style.display = 'none';
      document.getElementById('uploadBtn').disabled = true;
      document.getElementById('clearBtn').style.display = 'flex';
      setStatus('ready', '就绪');
      updateProgress(0, '就绪');
      document.getElementById('progressWrapper').classList.remove('active');
    }

    function handleFileSelect(file) {
      if (file.size > MAX_SIZE) {
        setMessage(`文件过大（${formatFileSize(file.size)}），最大支持 ${formatFileSize(MAX_SIZE)}`, 'error');
        return;
      }

      const dangerousExt = ['.php', '.exe', '.sh', '.bat', '.html', '.htm', '.asp', '.jsp'];
      const ext = file.name.substring(file.name.lastIndexOf('.')).toLowerCase();
      if (dangerousExt.includes(ext)) {
        setMessage(`不允许上传 ${ext} 类型的文件`, 'error');
        return;
      }

      currentFile = file;
      const nameEl = document.getElementById('fileName');
      const sizeEl = document.getElementById('fileSize');
      const iconEl = document.querySelector('.file-info .icon-file');
      nameEl.textContent = file.name;
      nameEl.className = 'name';
      sizeEl.textContent = formatFileSize(file.size);
      sizeEl.style.display = 'inline';
      iconEl.setAttribute('data-lucide', getFileIcon(file.name));
      document.getElementById('uploadBtn').disabled = false;
      setStatus('ready', '就绪');
      updateProgress(0, '就绪');
      setMessage(`已选择：${file.name}（${formatFileSize(file.size)}）`, 'info');
      renderIcons();
    }

    // Upload zone click - fileInput is outside zone so no bubble issue
    uploadZone.addEventListener('click', (e) => {
      if (!isUploading) {
        e.preventDefault();
        fileInput.click();
      }
    });

    uploadZone.addEventListener('dragover', (e) => {
      e.preventDefault();
      if (!isUploading) uploadZone.classList.add('dragover');
    });

    uploadZone.addEventListener('dragleave', (e) => {
      e.preventDefault();
      uploadZone.classList.remove('dragover');
    });

    uploadZone.addEventListener('drop', (e) => {
      e.preventDefault();
      uploadZone.classList.remove('dragover');
      if (isUploading) return;
      const files = e.dataTransfer.files;
      if (files.length > 0) handleFileSelect(files[0]);
    });

    fileInput.addEventListener('change', (e) => {
      const file = e.target.files[0];
      if (file) handleFileSelect(file);
    });

    document.getElementById('clearBtn').addEventListener('click', () => {
      if (isUploading) {
        setMessage('上传中，无法清除', 'warning');
        return;
      }
      resetFileSelection();
      setMessage('已清除文件选择', 'info');
    });

    document.getElementById('uploadBtn').addEventListener('click', async () => {
      if (!currentFile || isUploading) return;

      isUploading = true;
      const file = currentFile;
      document.getElementById('uploadBtn').disabled = true;
      document.getElementById('clearBtn').disabled = true;
      document.getElementById('uploadBtnText').textContent = '上传中...';
      const uploadIcon = document.getElementById('uploadBtnIcon');
      uploadIcon.setAttribute('data-lucide', 'loader-circle');
      renderIcons();

      setStatus('uploading', '上传中...');
      setMessage(`正在上传 ${file.name}...`, 'info');
      document.getElementById('progressWrapper').classList.add('active');
      updateProgress(0, '开始上传...');

      try {
        const formData = new FormData();
        formData.append('file', file);

        await new Promise((resolve, reject) => {
          const xhr = new XMLHttpRequest();
          xhr.open('POST', '/api/upload', true);

          xhr.upload.addEventListener('progress', (e) => {
            if (e.lengthComputable) {
              const percent = Math.round((e.loaded / e.total) * 100);
              updateProgress(percent, `上传中 ${percent}%`);
            }
          });

          xhr.onload = async function() {
            if (xhr.status >= 200 && xhr.status < 300) {
              try {
                const data = JSON.parse(xhr.responseText);
                resolve(data);
              } catch (e) {
                reject(new Error('响应解析失败'));
              }
            } else {
              try {
                const errData = JSON.parse(xhr.responseText);
                reject(new Error(errData.error || `上传失败（${xhr.status}）`));
              } catch (e) {
                reject(new Error(`上传失败（${xhr.status}）`));
              }
            }
          };

          xhr.onerror = () => reject(new Error('网络错误，上传中断'));
          xhr.ontimeout = () => reject(new Error('上传超时'));
          xhr.timeout = 120000;
          xhr.send(formData);
        });

        updateProgress(100, '上传完成');
        setStatus('success', '已完成');
        setMessage(`上传成功！"${file.name}" 已存储到 R2`, 'success');
        document.getElementById('clearBtn').style.display = 'none';
        loadFiles();

      } catch (err) {
        console.error('Upload error:', err);
        setStatus('error', '失败');
        setMessage(`上传失败：${err.message || '未知错误'}`, 'error');
      } finally {
        isUploading = false;
        document.getElementById('clearBtn').disabled = false;
        document.getElementById('uploadBtnText').textContent = '上传到 R2';
        uploadIcon.setAttribute('data-lucide', 'arrow-up');
        renderIcons();
      }
    });

    async function loadFiles() {
      const container = document.getElementById('filesListContainer');
      const refreshBtn = document.getElementById('refreshBtn');
      refreshBtn.classList.add('loading');
      container.innerHTML = `<div class="loading-state"><i data-lucide="loader-circle" class="icon"></i><div>加载中...</div></div>`;
      renderIcons();

      try {
        const response = await fetch('/api/list');
        if (!response.ok) throw new Error('加载失败');
        const data = await response.json();
        const files = data.files || [];
        document.getElementById('fileCount').textContent = files.length;

        if (files.length === 0) {
          container.innerHTML = `<div class="empty-state"><i data-lucide="folder" class="icon"></i><div>暂无文件</div></div>`;
        } else {
          container.innerHTML = `<div class="files-list">${files.map(file => `
            <div class="file-item">
              <i data-lucide="${getFileIcon(file.name)}" class="icon-file"></i>
              <div class="info">
                <div class="name" title="${file.name}">${file.name}</div>
                <div class="meta">${formatFileSize(file.size)} · ${formatTime(file.lastModified)}</div>
              </div>
              <div class="actions">
                <button class="action-btn delete" data-key="${file.key}" data-name="${file.name}" title="删除">
                  <i data-lucide="trash-2" class="icon"></i>
                </button>
              </div>
            </div>
          `).join('')}</div>`;
        }
        renderIcons();
      } catch (err) {
        container.innerHTML = `<div class="empty-state"><i data-lucide="alert-circle" class="icon" style="opacity:0.4;"></i><div>加载失败</div></div>`;
        renderIcons();
      } finally {
        refreshBtn.classList.remove('loading');
      }
    }

    document.getElementById('refreshBtn').addEventListener('click', loadFiles);

    document.getElementById('filesListContainer').addEventListener('click', async (e) => {
      const btn = e.target.closest('.action-btn.delete');
      if (!btn) return;
      const key = btn.dataset.key;
      const name = btn.dataset.name;
      if (!confirm(`确定删除「${name}」吗？`)) return;

      try {
        const response = await fetch(`/api/list?key=${encodeURIComponent(key)}`, { method: 'DELETE' });
        if (response.ok) {
          setMessage('文件已删除', 'success');
          loadFiles();
        } else {
          throw new Error('删除失败');
        }
      } catch (err) {
        setMessage(`删除失败：${err.message}`, 'error');
      }
    });

    document.addEventListener('keydown', (e) => {
      if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
        if (!isUploading && currentFile) {
          e.preventDefault();
          document.getElementById('uploadBtn').click();
        }
      }
    });

    window.addEventListener('beforeunload', (e) => {
      if (isUploading) {
        e.preventDefault();
        e.returnValue = '文件正在上传中，确定要离开吗？';
      }
    });

    // Init
    updateThemeIcon();
    loadFiles();
    renderIcons();
  </script>
</body>
</html>
