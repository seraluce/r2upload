---
import { siteConfig } from '../config.js';
---
<!DOCTYPE html>
<html lang="zh-CN" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content={siteConfig.pwa.themeColor} />
  <meta name="description" content={siteConfig.seo.description} />
  <meta name="robots" content="noindex, nofollow" />
  <link rel="canonical" href={`${siteConfig.url}/admin`} />
  <link rel="icon" type="image/svg+xml" href={siteConfig.logo} />
  <link rel="apple-touch-icon" href={siteConfig.logo} />
  <title>管理后台 - {siteConfig.name}</title>
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content={siteConfig.name} />
  <meta property="og:title" content={`管理后台 - ${siteConfig.name}`} />
  <meta property="og:description" content={siteConfig.seo.description} />
  <meta property="og:url" content={`${siteConfig.url}/admin`} />
  <meta property="og:image" content={siteConfig.seo.ogImage} />
  <meta property="og:locale" content="zh_CN" />
  <script src="https://unpkg.com/lucide@latest" is:inline></script>
  <style>
    :root {
      --bg: #ffffff;
      --bg-secondary: #fafafa;
      --bg-tertiary: #f4f4f5;
      --border: #eaeaea;
      --border-dark: #000000;
      --text: #000000;
      --text-secondary: #666666;
      --text-muted: #999999;
      --radius: 8px;
      --font: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      --mono: 'SF Mono', 'Monaco', 'Menlo', 'Consolas', monospace;
      --nav-height: 56px;
    }

    [data-theme="dark"] {
      --bg: #000000;
      --bg-secondary: #0a0a0a;
      --bg-tertiary: #111111;
      --border: #262626;
      --border-dark: #ffffff;
      --text: #ededed;
      --text-secondary: #888888;
      --text-muted: #666666;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: var(--font);
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
      transition: background 0.15s ease, color 0.15s ease;
    }

    /* Navbar */
    .navbar {
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--bg);
      border-bottom: 1px solid var(--border);
      backdrop-filter: saturate(180%) blur(12px);
      -webkit-backdrop-filter: saturate(180%) blur(12px);
    }
    .nav-inner {
      max-width: 840px;
      margin: 0 auto;
      padding: 0 24px;
      height: var(--nav-height);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .nav-brand {
      display: flex;
      align-items: center;
      gap: 8px;
      font-weight: 600;
      font-size: 15px;
      letter-spacing: -0.02em;
      color: var(--text);
      text-decoration: none;
    }
    .nav-brand .icon { width: 20px; height: 20px; stroke-width: 1.5; }
    .nav-links {
      display: flex;
      align-items: center;
      gap: 4px;
    }
    .nav-link {
      padding: 6px 12px;
      font-size: 13px;
      color: var(--text-secondary);
      text-decoration: none;
      border-radius: 6px;
      transition: color 0.15s ease, background 0.15s ease;
    }
    .nav-link:hover { color: var(--text); background: var(--bg-tertiary); }
    .nav-link.active { color: var(--text); }
    .nav-right {
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .theme-toggle {
      background: transparent;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      width: 32px;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: background 0.15s ease;
    }
    .theme-toggle:hover { background: var(--bg-tertiary); }
    .theme-toggle .icon { width: 16px; height: 16px; color: var(--text-secondary); stroke-width: 1.5; }

    .page-container { display: flex; justify-content: center; padding: 40px 24px; }
    .card { width: 100%; max-width: 800px; }

    /* Header */
    .header { margin-bottom: 24px; }
    .header h1 { font-size: 22px; font-weight: 600; letter-spacing: -0.02em; margin-bottom: 4px; }
    .header-desc { font-size: 14px; color: var(--text-secondary); }

    /* Login */
    .login-card { max-width: 400px; margin: 0 auto; }
    .login-icon-wrap { display: flex; justify-content: center; margin-bottom: 16px; }
    .login-icon-wrap .icon { width: 40px; height: 40px; color: var(--text); stroke-width: 1; }
    .login-title { font-size: 18px; font-weight: 600; text-align: center; margin-bottom: 4px; letter-spacing: -0.02em; }
    .login-subtitle { font-size: 13px; color: var(--text-muted); text-align: center; margin-bottom: 24px; }
    .login-form { display: flex; flex-direction: column; gap: 12px; }
    .input-group { position: relative; }
    .input-group .input-icon { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); width: 16px; height: 16px; color: var(--text-muted); stroke-width: 1.5; }
    .input-group input { width: 100%; padding: 10px 12px 10px 36px; border: 1px solid var(--border); border-radius: var(--radius); font-size: 13px; color: var(--text); background: var(--bg); transition: border-color 0.15s ease; font-family: var(--font); }
    .input-group input:focus { outline: none; border-color: var(--border-dark); }
    .input-group input::placeholder { color: var(--text-muted); }
    .error-message { padding: 8px 12px; border: 1px solid var(--border-dark); border-radius: var(--radius); font-size: 12px; color: var(--text); display: flex; align-items: center; gap: 6px; }
    .error-message .icon { width: 14px; height: 14px; stroke-width: 1.5; flex-shrink: 0; }
    .btn { padding: 8px 16px; border: 1px solid var(--border); border-radius: var(--radius); font-size: 13px; font-weight: 500; cursor: pointer; transition: background 0.15s ease; display: flex; align-items: center; justify-content: center; gap: 6px; background: var(--bg); color: var(--text); font-family: var(--font); }
    .btn .icon { width: 14px; height: 14px; stroke-width: 1.5; flex-shrink: 0; }
    .btn:hover:not(:disabled) { background: var(--bg-tertiary); }
    .btn:disabled { opacity: 0.4; cursor: not-allowed; }
    .btn-primary { background: var(--text); color: var(--bg); border-color: var(--text); }
    .btn-primary:hover:not(:disabled) { opacity: 0.9; background: var(--text); }
    .btn-primary .icon { color: var(--bg); }

    /* Toolbar */
    .toolbar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; gap: 12px; flex-wrap: wrap; }
    .toolbar-left { display: flex; align-items: center; gap: 12px; }
    .file-count { font-size: 12px; color: var(--text-muted); font-family: var(--mono); }
    .toolbar-right { display: flex; gap: 8px; }
    .search-input { position: relative; }
    .search-input .search-icon { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); width: 14px; height: 14px; color: var(--text-muted); stroke-width: 1.5; }
    .search-input input { padding: 6px 10px 6px 30px; border: 1px solid var(--border); border-radius: var(--radius); font-size: 12px; color: var(--text); background: var(--bg); width: 200px; transition: border-color 0.15s ease; font-family: var(--font); }
    .search-input input:focus { outline: none; border-color: var(--border-dark); }
    .search-input input::placeholder { color: var(--text-muted); }

    /* Files list */
    .files-list { border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
    .file-item { display: flex; align-items: center; gap: 10px; padding: 10px 14px; border-bottom: 1px solid var(--border); font-size: 13px; transition: background 0.15s ease; }
    .file-item:last-child { border-bottom: none; }
    .file-item:hover { background: var(--bg-secondary); }
    .file-item .thumb { width: 40px; height: 40px; border-radius: var(--radius); object-fit: cover; border: 1px solid var(--border); flex-shrink: 0; }
    .file-item .icon-file { width: 40px; height: 40px; color: var(--text-muted); stroke-width: 1.5; flex-shrink: 0; padding: 8px; }
    .file-item .info { flex: 1; min-width: 0; }
    .file-item .info .name { color: var(--text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 13px; }
    .file-item .info .path { color: var(--text-muted); font-size: 11px; margin-top: 2px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-family: var(--mono); }
    .file-item .info .meta { color: var(--text-muted); font-size: 11px; margin-top: 2px; font-family: var(--mono); }
    .file-item .actions { display: flex; gap: 2px; flex-shrink: 0; }
    .file-item .action-btn { width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; background: transparent; border: none; border-radius: 6px; cursor: pointer; transition: background 0.15s ease; padding: 0; }
    .file-item .action-btn:hover { background: var(--bg-tertiary); }
    .file-item .action-btn .icon { width: 14px; height: 14px; stroke-width: 1.5; color: var(--text-muted); }
    .file-item .action-btn.delete:hover .icon { color: var(--text); }
    .file-item .action-btn.preview:hover .icon { color: var(--text); }
    .file-item .action-btn.copy:hover .icon { color: var(--text); }

    .empty-state { text-align: center; padding: 48px 20px; color: var(--text-muted); font-size: 13px; border: 1px solid var(--border); border-radius: var(--radius); }
    .empty-state .icon { width: 28px; height: 28px; margin-bottom: 8px; opacity: 0.3; }
    .loading-state { text-align: center; padding: 48px 20px; color: var(--text-muted); font-size: 13px; border: 1px solid var(--border); border-radius: var(--radius); }
    .loading-state .icon { width: 20px; height: 20px; margin-bottom: 8px; animation: spin 1s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* Modal */
    .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.6); display: flex; align-items: center; justify-content: center; z-index: 1000; padding: 24px; display: none; }
    [data-theme="dark"] .modal-overlay { background: rgba(0,0,0,0.8); }
    .modal-overlay.active { display: flex; }
    .modal { background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius); max-width: 90vw; max-height: 90vh; display: flex; flex-direction: column; overflow: hidden; }
    .modal-header { display: flex; align-items: center; justify-content: space-between; padding: 12px 16px; border-bottom: 1px solid var(--border); gap: 12px; }
    .modal-header h3 { font-size: 13px; font-weight: 500; color: var(--text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex: 1; }
    .modal-close { width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; background: transparent; border: none; border-radius: 6px; cursor: pointer; transition: background 0.15s ease; flex-shrink: 0; }
    .modal-close:hover { background: var(--bg-tertiary); }
    .modal-close .icon { width: 16px; height: 16px; color: var(--text-secondary); stroke-width: 1.5; }
    .modal-body { padding: 16px; overflow: auto; flex: 1; display: flex; align-items: center; justify-content: center; min-width: 300px; min-height: 200px; }
    .modal-body img { max-width: 100%; max-height: 70vh; object-fit: contain; }
    .modal-body video { max-width: 100%; max-height: 70vh; }
    .modal-body audio { width: 100%; min-width: 300px; }
    .modal-body .text-preview { background: var(--bg-secondary); padding: 14px; border-radius: var(--radius); border: 1px solid var(--border); font-family: var(--mono); font-size: 12px; white-space: pre-wrap; word-break: break-all; max-height: 500px; overflow: auto; width: 600px; color: var(--text); }
    .modal-footer { padding: 10px 16px; border-top: 1px solid var(--border); display: flex; justify-content: flex-end; gap: 8px; }

    /* Toast */
    .toast { position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%) translateY(100px); background: var(--text); color: var(--bg); padding: 8px 16px; border-radius: var(--radius); font-size: 13px; z-index: 2000; transition: transform 0.2s ease; display: flex; align-items: center; gap: 6px; }
    .toast.show { transform: translateX(-50%) translateY(0); }
    .toast .icon { width: 14px; height: 14px; stroke-width: 1.5; }

    @media (max-width: 600px) {
      .nav-inner { padding: 0 16px; }
      .page-container { padding: 20px 16px; }
      .toolbar { flex-direction: column; align-items: stretch; }
      .toolbar-right { justify-content: flex-end; }
      .search-input input { width: 100%; }
      .file-item { flex-wrap: wrap; }
      .file-item .actions { width: 100%; justify-content: flex-end; }
    }
  </style>
</head>
<body>
  <nav class="navbar">
    <div class="nav-inner">
      <a href="/" class="nav-brand">
        <i data-lucide="hard-drive" class="icon"></i>
        <span>{siteConfig.name}</span>
      </a>
      <div class="nav-right">
        <div class="nav-links">
          {siteConfig.nav.map(item => (
            <a href={item.href} class={`nav-link${item.href === '/admin' ? ' active' : ''}`}>{item.name}</a>
          ))}
        </div>
        <button class="theme-toggle" id="themeToggle" title="切换主题">
          <i data-lucide="moon" class="icon" id="themeIcon"></i>
        </button>
      </div>
    </div>
  </nav>

  <div class="page-container">
    <!-- Login Card -->
    <div class="card login-card" id="loginCard">
      <div class="header" style="text-align:center;">
        <div class="login-icon-wrap">
          <i data-lucide="lock" class="icon"></i>
        </div>
        <h1>管理后台</h1>
        <p class="header-desc">请输入密码以继续</p>
      </div>
      <div class="login-form">
        <div class="input-group">
          <i data-lucide="key" class="input-icon"></i>
          <input type="password" id="passwordInput" placeholder="密码" />
        </div>
        <div id="loginError" style="display:none;" class="error-message">
          <i data-lucide="alert-circle" class="icon"></i>
          <span id="loginErrorText">密码错误</span>
        </div>
        <button class="btn btn-primary" id="loginBtn">
          <i data-lucide="log-in" class="icon"></i>
          登录
        </button>
      </div>
    </div>

    <!-- Admin Card -->
    <div class="card" id="adminCard" style="display:none;">
      <div class="header">
        <h1>文件管理</h1>
        <p class="header-desc">管理存储桶中的所有文件</p>
      </div>

      <div class="toolbar">
        <div class="toolbar-left">
          <div class="search-input">
            <i data-lucide="search" class="search-icon"></i>
            <input type="text" id="searchInput" placeholder="搜索文件..." />
          </div>
          <span class="file-count" id="fileCount">0 个文件</span>
        </div>
        <div class="toolbar-right">
          <button class="btn" id="logoutBtn">
            <i data-lucide="log-out" class="icon"></i>
            退出
          </button>
          <button class="btn btn-primary" id="refreshBtn">
            <i data-lucide="refresh-cw" class="icon"></i>
            刷新
          </button>
        </div>
      </div>

      <div id="filesList">
        <div class="loading-state">
          <i data-lucide="loader-circle" class="icon"></i>
          <div>加载中...</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Preview Modal -->
  <div class="modal-overlay" id="previewModal">
    <div class="modal">
      <div class="modal-header">
        <h3 id="previewFileName">文件预览</h3>
        <button class="modal-close" id="closePreview">
          <i data-lucide="x" class="icon"></i>
        </button>
      </div>
      <div class="modal-body" id="previewBody"></div>
      <div class="modal-footer">
        <button class="btn" id="copyUrlFromPreview">
          <i data-lucide="link" class="icon"></i>
          复制链接
        </button>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div class="toast" id="toast">
    <i data-lucide="check" class="icon" id="toastIcon"></i>
    <span id="toastText">已复制</span>
  </div>

  <script is:inline>
    let r2PublicUrlPrefix = '';

    const savedTheme = localStorage.getItem('theme') || 'light';
    document.documentElement.setAttribute('data-theme', savedTheme);

    let currentFiles = [];
    let filteredFiles = [];
    let currentPreviewKey = '';

    function showToast(message, type) {
      const toast = document.getElementById('toast');
      const toastText = document.getElementById('toastText');
      const toastIcon = document.getElementById('toastIcon');
      toastText.textContent = message;
      const iconMap = { success:'check', error:'x', info:'info' };
      toastIcon.setAttribute('data-lucide', iconMap[type] || 'check');
      try { lucide.createIcons(); } catch(e) {}
      toast.classList.add('show');
      setTimeout(() => { toast.classList.remove('show'); }, 2000);
    }

    function formatFileSize(bytes) {
      if (bytes === 0) return '0 B';
      const units = ['B', 'KB', 'MB', 'GB', 'TB'];
      const i = Math.floor(Math.log(bytes) / Math.log(1024));
      return `${(bytes / Math.pow(1024, i)).toFixed(1)} ${units[i]}`;
    }

    function formatTime(isoString) {
      const date = new Date(isoString);
      return date.toLocaleString('zh-CN', { year:'numeric', month:'2-digit', day:'2-digit', hour:'2-digit', minute:'2-digit' });
    }

    function getFileIcon(filename) {
      const ext = filename.substring(filename.lastIndexOf('.')).toLowerCase();
      const iconMap = {
        '.pdf':'file-text','.doc':'file-text','.docx':'file-text','.txt':'file-text','.md':'file-text',
        '.jpg':'image','.jpeg':'image','.png':'image','.gif':'image','.svg':'image','.webp':'image','.bmp':'image',
        '.mp4':'video','.mov':'video','.avi':'video','.webm':'video','.mkv':'video',
        '.mp3':'music','.wav':'music','.flac':'music','.ogg':'music',
        '.zip':'archive','.rar':'archive','.tar':'archive','.gz':'archive','.7z':'archive',
        '.json':'file-code','.js':'file-code','.ts':'file-code','.html':'file-code','.css':'file-code','.py':'file-code',
        '.csv':'file-spreadsheet','.xls':'file-spreadsheet','.xlsx':'file-spreadsheet',
        '.ppt':'file-presentation','.pptx':'file-presentation',
      };
      return iconMap[ext] || 'file';
    }

    function canPreview(filename) {
      const ext = filename.substring(filename.lastIndexOf('.')).toLowerCase();
      return ['.jpg','.jpeg','.png','.gif','.svg','.webp','.bmp','.mp4','.webm','.mp3','.ogg','.wav','.txt','.md','.json','.csv'].includes(ext);
    }
    function isImage(n){const e=n.substring(n.lastIndexOf('.')).toLowerCase();return['.jpg','.jpeg','.png','.gif','.svg','.webp','.bmp'].includes(e);}
    function isVideo(n){const e=n.substring(n.lastIndexOf('.')).toLowerCase();return['.mp4','.webm'].includes(e);}
    function isAudio(n){const e=n.substring(n.lastIndexOf('.')).toLowerCase();return['.mp3','.ogg','.wav'].includes(e);}
    function isText(n){const e=n.substring(n.lastIndexOf('.')).toLowerCase();return['.txt','.md','.json','.csv','.html','.css','.js'].includes(e);}

    async function checkAuth() {
      try {
        const r = await fetch('/api/admin/auth', { credentials: 'same-origin' });
        const d = await r.json();
        return d.authenticated;
      } catch { return false; }
    }

    async function login(password) {
      try {
        const r = await fetch('/api/admin/auth', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
          body: JSON.stringify({ password })
        });
        const d = await r.json();
        return d.success;
      } catch { return false; }
    }

    async function loadFiles() {
      const list = document.getElementById('filesList');
      list.innerHTML = `<div class="loading-state"><i data-lucide="loader-circle" class="icon"></i><div>加载中...</div></div>`;
      try { lucide.createIcons(); } catch(e) {}
      try {
        const r = await fetch('/api/admin/files', { credentials: 'same-origin' });
        if (r.status === 401) { showLogin(); return; }
        const d = await r.json();
        currentFiles = d.files || [];
        filteredFiles = [...currentFiles];
        r2PublicUrlPrefix = d.publicUrlPrefix || '';
        renderFiles();
      } catch {
        list.innerHTML = `<div class="empty-state"><i data-lucide="alert-circle" class="icon" style="opacity:0.4;"></i><div>加载失败</div></div>`;
        try { lucide.createIcons(); } catch(e) {}
      }
    }

    function renderFiles() {
      const list = document.getElementById('filesList');
      const count = document.getElementById('fileCount');
      count.textContent = `${filteredFiles.length} 个文件`;
      if (filteredFiles.length === 0) {
        list.innerHTML = `<div class="empty-state"><i data-lucide="folder" class="icon"></i><div>暂无文件</div></div>`;
        try { lucide.createIcons(); } catch(e) {}
        return;
      }
      list.innerHTML = `<div class="files-list">${filteredFiles.map(f => {
        const fileUrl = getFileUrl(f.key);
        const isImg = isImage(f.name);
        const thumb = isImg && r2PublicUrlPrefix ? `<img src="${fileUrl}" class="thumb" alt="" loading="lazy" />` : `<i data-lucide="${getFileIcon(f.name)}" class="icon-file"></i>`;
        const shortUrl = fileUrl.length > 55 ? fileUrl.substring(0, 30) + '...' + fileUrl.substring(fileUrl.length - 20) : fileUrl;
        return `
        <div class="file-item">
          ${thumb}
          <div class="info">
            <div class="name" title="${f.name}">${f.name}</div>
            <div class="path" title="${fileUrl}">${shortUrl}</div>
            <div class="meta">${formatFileSize(f.size)} · ${formatTime(f.lastModified)}</div>
          </div>
          <div class="actions">
            ${canPreview(f.name) ? `<button class="action-btn preview" data-action="preview" data-key="${f.key}" data-name="${f.name}" title="预览"><i data-lucide="eye" class="icon"></i></button>` : ''}
            <button class="action-btn copy" data-action="copy" data-key="${f.key}" title="复制链接"><i data-lucide="link" class="icon"></i></button>
            <button class="action-btn delete" data-action="delete" data-key="${f.key}" data-name="${f.name}" title="删除"><i data-lucide="trash-2" class="icon"></i></button>
          </div>
        </div>
      `}).join('')}</div>`;
      try { lucide.createIcons(); } catch(e) {}
    }

    function filterFiles(q) {
      const lq = q.toLowerCase();
      filteredFiles = currentFiles.filter(f => f.name.toLowerCase().includes(lq) || f.key.toLowerCase().includes(lq));
      renderFiles();
    }

    async function deleteFile(key, name) {
      if (!confirm(`确定删除「${name}」吗？`)) return;
      try {
        const r = await fetch(`/api/admin/files?key=${encodeURIComponent(key)}`, { method: 'DELETE', credentials: 'same-origin' });
        if (r.status === 401) { showLogin(); return; }
        if (r.ok) { showToast('已删除', 'success'); loadFiles(); }
        else { showToast('删除失败', 'error'); }
      } catch { showToast('删除失败', 'error'); }
    }

    function getFileUrl(key) {
      return r2PublicUrlPrefix ? `${r2PublicUrlPrefix}/${key}` : key;
    }

    function copyUrl(key) {
      const url = getFileUrl(key);
      navigator.clipboard.writeText(url).then(() => showToast('链接已复制', 'success')).catch(() => showToast('复制失败', 'error'));
    }

    async function previewFile(key, name) {
      currentPreviewKey = key;
      const modal = document.getElementById('previewModal');
      const body = document.getElementById('previewBody');
      const fname = document.getElementById('previewFileName');
      fname.textContent = name;
      body.innerHTML = `<div class="loading-state" style="padding:40px;border:none;"><i data-lucide="loader-circle" class="icon"></i><div>加载中...</div></div>`;
      try { lucide.createIcons(); } catch(e) {}
      modal.classList.add('active');
      try {
        const fileUrl = getFileUrl(key);
        if (isImage(name)) {
          body.innerHTML = `
            <div style="display:flex;flex-direction:column;align-items:center;gap:16px;width:100%;">
              <img src="${fileUrl}" alt="${name}" style="max-width:400px;max-height:400px;object-fit:contain;border:1px solid var(--border);border-radius:var(--radius);" />
              <div style="display:flex;gap:8px;flex-wrap:wrap;justify-content:center;">
                <button class="btn" onclick="window.open('${fileUrl}', '_blank')">
                  <i data-lucide="maximize-2" class="icon"></i>
                  查看大图
                </button>
                <button class="btn" onclick="copyUrl('${key}')">
                  <i data-lucide="link" class="icon"></i>
                  复制链接
                </button>
              </div>
            </div>
          `;
          try { lucide.createIcons(); } catch(e) {}
        } else if (isVideo(name)) {
          body.innerHTML = `<video src="${fileUrl}" controls autoplay></video>`;
        } else if (isAudio(name)) {
          body.innerHTML = `<audio src="${fileUrl}" controls autoplay></audio>`;
        } else if (isText(name)) {
          const tr = await fetch(`${fileUrl}`);
          const text = await tr.text();
          body.innerHTML = `<div class="text-preview">${escapeHtml(text)}</div>`;
        } else {
          body.innerHTML = `<div class="empty-state" style="border:none;"><i data-lucide="file" class="icon"></i><div>此文件类型暂不支持预览</div></div>`;
          try { lucide.createIcons(); } catch(e) {}
        }
      } catch {
        body.innerHTML = `<div class="empty-state" style="border:none;"><i data-lucide="alert-circle" class="icon"></i><div>预览加载失败</div></div>`;
        try { lucide.createIcons(); } catch(e) {}
      }
    }

    function escapeHtml(text) {
      const d = document.createElement('div');
      d.textContent = text;
      return d.innerHTML;
    }

    function showLogin() {
      document.getElementById('loginCard').style.display = 'block';
      document.getElementById('adminCard').style.display = 'none';
    }
    function showAdmin() {
      document.getElementById('loginCard').style.display = 'none';
      document.getElementById('adminCard').style.display = 'block';
      loadFiles();
    }

    function handleThemeToggle() {
      const cur = document.documentElement.getAttribute('data-theme');
      const next = cur === 'light' ? 'dark' : 'light';
      document.documentElement.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
      updateThemeIcon();
    }
    function updateThemeIcon() {
      const t = document.documentElement.getAttribute('data-theme');
      const i = document.getElementById('themeIcon');
      if (i) { i.setAttribute('data-lucide', t === 'dark' ? 'sun' : 'moon'); try { lucide.createIcons(); } catch(e) {} }
    }

    function logout() {
      document.cookie = 'admin_auth=; Path=/; expires=Thu, 01 Jan 1970 00:00:00 UTC;';
      showLogin();
    }

    document.getElementById('loginBtn').addEventListener('click', async () => {
      const pwd = document.getElementById('passwordInput').value;
      const err = document.getElementById('loginError');
      const errText = document.getElementById('loginErrorText');
      const btn = document.getElementById('loginBtn');
      if (!pwd) { errText.textContent = '请输入密码'; err.style.display = 'flex'; return; }
      btn.disabled = true; err.style.display = 'none';
      const ok = await login(pwd);
      if (ok) showAdmin();
      else { errText.textContent = '密码错误'; err.style.display = 'flex'; btn.disabled = false; }
    });

    document.getElementById('passwordInput').addEventListener('keydown', (e) => {
      if (e.key === 'Enter') document.getElementById('loginBtn').click();
    });

    document.getElementById('refreshBtn').addEventListener('click', loadFiles);
    document.getElementById('themeToggle').addEventListener('click', handleThemeToggle);
    document.getElementById('logoutBtn').addEventListener('click', logout);
    document.getElementById('searchInput').addEventListener('input', (e) => filterFiles(e.target.value));

    document.getElementById('filesList').addEventListener('click', (e) => {
      const btn = e.target.closest('[data-action]');
      if (!btn) return;
      const action = btn.dataset.action;
      const key = btn.dataset.key;
      const name = btn.dataset.name;
      if (action === 'delete') deleteFile(key, name);
      else if (action === 'copy') copyUrl(key);
      else if (action === 'preview') previewFile(key, name);
    });

    document.getElementById('closePreview').addEventListener('click', () => {
      document.getElementById('previewModal').classList.remove('active');
    });
    document.getElementById('previewModal').addEventListener('click', (e) => {
      if (e.target.id === 'previewModal') document.getElementById('previewModal').classList.remove('active');
    });
    document.getElementById('copyUrlFromPreview').addEventListener('click', () => {
      if (currentPreviewKey) copyUrl(currentPreviewKey);
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') document.getElementById('previewModal').classList.remove('active');
    });

    updateThemeIcon();
    checkAuth().then(authed => {
      if (authed) showAdmin();
      else showLogin();
      try { lucide.createIcons(); } catch(e) {}
    });
  </script>
</body>
</html>
